%% Gavel — Three-Memory Architecture (Mermaid source for Devpost markdown / quick edits).
%% The SVG (three-memory-architecture.svg) is the polished export; this is the editable
%% structural twin. Grounded in the actually-built system — no aspirational boxes.
flowchart TB
  subgraph SLACK["SLACK WORKSPACE — what neighbors see  ★ Slack Platform: Bolt · Block Kit · App Home · Assistant threads (Slack AI)"]
    direction LR
    S1["📣 Proactive alert cards<br/>Block Kit · EN/ES"]
    S2["⌨️ Slash commands<br/>/gavel …"]
    S3["🏠 App Home<br/>subscriptions · watches"]
    S4["💬 Assistant threads<br/>ask Gavel · EN/ES"]
  end

  POLLER["⏱ Poller — gavel-poller · Fly.io · supercronic<br/>*/5 poll→detect→summarize→alert · 0 */6 escalation<br/>0 13 watch sweep · 0 14 Sun digest · walk-on detector"]

  AGENT["🧠 Gavel Agent — gavel-app · Slack Bolt (Socket Mode)<br/><b>Claude Sonnet 4.6</b> — summarize · agent loop · tool routing<br/>Generates EN + ES natively (no translation API)"]

  STATE["🗄 Convex — app state + cache<br/>subscriptions · watches · watchAlerts · matterEscalations<br/>detectedAgendaItems · councilMembers · cached lookups<br/><i>civic-record keys only — never Slack message content</i>"]

  M1["①  STRUCTURED CIVIC DATA  🟢 public · live<br/><b>Milwaukee Civic MCP server</b> (custom, open-source) ★<br/>Legistar Web API (OData) + Milwaukee CKAN datastore<br/>get_matter · get_matter_history · search_matters · get_sponsors<br/>get_upcoming_events · lookup_parcel · get_permits<br/>get_ownership_portfolio · check_zoning<br/><b>LIVE · AUTHORITATIVE · NOT STORED</b>"]

  M2["②  SEMANTIC CIVIC MEMORY  🟢 public · indexed<br/><b>Convex vector database</b><br/>namespace zoning_code — Zoning Code Ch. 295<br/>116 chunks · OpenAI text-embedding-3-small<br/>ask_zoning_code → §295-NNN citations<br/><b>INDEXED · PUBLIC RECORD ONLY</b><br/><i>transcripts namespace — roadmap (Phase 4)</i>"]

  M3["③  LIVE COMMUNITY MEMORY  🔵 private · live only<br/><b>Slack Real-Time Search API</b> ★<br/>assistant.search.context — the workspace's own history<br/>EN + ES merged → search_community_memory<br/><b>LIVE · NEVER STORED / COPIED / INDEXED</b>"]

  COMPLIANCE["⚖️ COMPLIANCE BY DESIGN — the load-bearing claim<br/><b>Indexes the PUBLIC record</b> (zoning, agendas → Convex; civic APIs → MCP, live)<br/><b>Queries the PRIVATE record live</b> (Slack messages → RTS — never stored, copied, or indexed)<br/>The ToS-safe fusion of official civic memory + community memory. (mem0 was deliberately rejected.)"]

  POLLER -->|proactive push| SLACK
  SLACK <-->|ask / reply| AGENT
  AGENT <--> STATE
  AGENT --> M1
  AGENT --> M2
  AGENT --> M3
  M1 -.-> COMPLIANCE
  M2 -.-> COMPLIANCE
  M3 -.-> COMPLIANCE

  classDef public fill:#f0fdf4,stroke:#16a34a,stroke-width:2px,color:#0f172a;
  classDef private fill:#eff6ff,stroke:#2563eb,stroke-width:2px,color:#0f172a;
  classDef agent fill:#eef2ff,stroke:#4f46e5,stroke-width:2px,color:#0f172a;
  classDef poller fill:#fffbeb,stroke:#f59e0b,color:#0f172a;
  classDef state fill:#f0fdfa,stroke:#0d9488,color:#0f172a;
  classDef comply fill:#ffffff,stroke:#cbd5e1,color:#0f172a;
  class M1,M2 public;
  class M3 private;
  class AGENT agent;
  class POLLER poller;
  class STATE state;
  class COMPLIANCE comply;
